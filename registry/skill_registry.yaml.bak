  outputs: [dialog resolution]
  allowed_paths: ["~/.hermes/**"]
  forbidden_paths: []
  tools_required: [dialog_watcher]
  permission_level: write_within_scope
  risk_level: medium
  owner_approval_required: false
  validation: [dialog resolved]

- id: skill-relay-skill-governance
  name: Relay Skill Governance — pm-relay 同步检查
  type: skill
  status: active
  purpose: 比对 pm-relay SKILL.md 与 reference 文件的漂移 — 检测路径过时、内容不一致、版本落差。govarnance 层只读审计 skill
  depends_on: [skill-pm-relay]
  applicable_lanes: [A_LINE_FORMAL, WORKYB_RUNTIME]
  inputs: [pm-relay skill + references]
  outputs: [sync check report]
  allowed_paths: ["~/.hermes/skills/pm-runtime/pm-relay/**"]
  forbidden_paths: []
  tools_required: [python3, grep]
  permission_level: readonly
  risk_level: low
  owner_approval_required: false
  validation: [loadable, report generated]

