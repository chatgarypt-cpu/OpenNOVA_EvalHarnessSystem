- id: skill-path-resolver
  name: Path Resolver — 路径防漂移模块
  type: skill
  status: active
  purpose: PM Runtime 路径防漂移 — 从单一 project_root 基址派生所有路径，校验存在性，生成缺失报告。迁移时只改一个变量。
  applicable_lanes: [ALL]
  inputs: [project_root (auto-detect)]
  outputs: [resolved path, existence check, missing report]
  allowed_paths: ["~/项目开发/**", "~/.hermes/**"]
  forbidden_paths: []
  tools_required: [python3]
  permission_level: readonly
  risk_level: low
  owner_approval_required: false
  validation: [path exists, exit code 0]
  features:
    - single_root_derivation: true
    - existence_validation: true
    - migration_ready: true
    - missing_report: true

